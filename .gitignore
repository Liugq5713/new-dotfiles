# Tmux plugins (installed by tpm at runtime)
tmux/.config/tmux/plugins/

# Neovim plugin cache and state
nvim/.config/nvim/plugin/

# Alacritty themes (cloned at install time, 148 files we don't need in git)
alacritty/.config/alacritty/themes/

# OS files
.DS_Store

# tpm 管理的插件目录，通过 tpm 自动安装，不纳入版本控制
plugins/

# tmux-resurrect 会话保存数据
resurrect/

